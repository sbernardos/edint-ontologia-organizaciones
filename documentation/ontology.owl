    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#dependsOnRoot -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#dependsOnRoot">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/org#subOrganizationOf"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization"/>
        <rdfs:comment xml:lang="en">It relates an organization to the organization at the highest level of hierarchy on which it depends.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una organización con la organización al nivel máximo de jerarquía de la que depende.</rdfs:comment>
        <rdfs:label xml:lang="es">depende de organización raíz</rdfs:label>
        <rdfs:label xml:lang="en">depends on root organization</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasAdministrationLevel -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasAdministrationLevel">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/AdministrationLevel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an organization to a skos concept that is in the administration level taxonomy of to which an organization belongs.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una organización con un concepto skos que está en la taxonomía de nivel de administración al que pertenece una organización.</rdfs:comment>
        <rdfs:label xml:lang="en">has administration level</rdfs:label>
        <rdfs:label xml:lang="es">tiene nivel de administración</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasCompeteceRegion -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasCompeteceRegion">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization"/>
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/GovernmentalAdministrativeRegion"/>
        <rdfs:comment xml:lang="en">It relates an organization to the administrative region where it exercises its powers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una organización con el ámbito territorial de ejercicio de sus competencias.</rdfs:comment>
        <rdfs:label xml:lang="en">has competence region</rdfs:label>
        <rdfs:label xml:lang="es">tiene ámbito de competencia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasOrganizationStatus -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasOrganizationStatus">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/OrganizationStatus"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an organization to a skos concept that is in the taxonomy of status or legal/functional situation of an organization.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una organización con un concepto skos que está en la taxonomía de estados o situación jurídico/funcional de una organización.</rdfs:comment>
        <rdfs:label xml:lang="en">has organization status</rdfs:label>
        <rdfs:label xml:lang="es">tiene estado de organización</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasOrganizationType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#hasOrganizationType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/org#classification"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/OrganizationType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an organization to a skos concept that is in the taxonomy of organization types to which an organization belongs.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una organización con un concepto skos que está en la taxonomía de tipos de organización al que pertenece una organización.</rdfs:comment>
        <rdfs:label xml:lang="en">has organization type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de organización</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme">
        <rdfs:comment rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    </owl:ObjectProperty>
    


