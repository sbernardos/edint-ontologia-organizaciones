<?xml version="1.0"?>
<rdf:RDF xmlns="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#"
     xml:base="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:org="http://www.w3.org/ns/org#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#">
        <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#1.1.1"/>
        <owl:imports rdf:resource="http://www.w3.org/ns/org#"/>
        <dc:contributor>Antonio Ibáñez</dc:contributor>
        <dc:contributor>Carlos Jiménez</dc:contributor>
        <dc:contributor>David Rey Jordán</dc:contributor>
        <dc:contributor>Imanol Argüeso</dc:contributor>
        <dc:contributor>José Manuel Crespo</dc:contributor>
        <dc:contributor>José María Subero</dc:contributor>
        <dc:contributor>Martín Alvarez</dc:contributor>
        <dc:contributor>María Dolores Hernández</dc:contributor>
        <dc:contributor>María Jesús Fernández Ruíz</dc:contributor>
        <dc:contributor>Toño Velasco</dc:contributor>
        <dc:title xml:lang="en">The Spanish Public Organizations Ontology</dc:title>
        <terms:created>2026-05-07</terms:created>
        <terms:creator>Daniel Doña</terms:creator>
        <terms:creator>Edna Ruckhaus</terms:creator>
        <terms:creator>Lucía Sánchez</terms:creator>
        <terms:creator>Socorro Bernardos</terms:creator>
        <terms:creator>Óscar Corcho</terms:creator>
        <terms:description xml:lang="es">El propósito de esta ontología es proporcionar un vocabulario común para la representación de las organizaciones públicas en España, así como aspectos relacionados con los organigramas dentro de dichas organizaciones.
Es una actualización de una versión previa de la ontología que extendía la ontología del W3C para organizaciones (W3C Organization Ontology). Esta versión adapta esa ontología para cubrir los requisitos EDINT. Como cambios más relevantes, elimina las clases Oficina y Unidad con función de Gestión Económica-Presupuestaria, junto con sus propiedades específicas, e incluye edintinf:Equipamiento como subclase de Sede .</terms:description>
        <terms:description xml:lang="en">The purpose of this ontology is to provide a common vocabulary for representing public organizations in Spain, as well as aspects related to organizational charts within those organizations.
It is an update of a previous version of the ontology that extended the W3C Organization Ontology. This version adapts that ontology to meet EDINT requirements. The most relevant changes include removing the Office and Economic-Budgetary Management Unit classes, along with their specific properties, and including edintinf:Facility as a subclass of Site.</terms:description>
        <terms:issued>2015-02-19</terms:issued>
        <terms:license>Creative Commons Attribution 4.0 International (CC BY 4.0)</terms:license>
        <terms:title xml:lang="es">Ontología sobre Organizaciones Públicas en España</terms:title>
        <vann:preferredNamespacePrefix>edintorg</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#</vann:preferredNamespaceUri>
        <owl:versionInfo>0.2.0</owl:versionInfo>
    </owl:Ontology>
    


