     -->


    


    <!-- http://dbpedia.org/ontology/GovernmentalAdministrativeRegion -->


    <owl:Class rdf:about="http://dbpedia.org/ontology/GovernmentalAdministrativeRegion">
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#OrganicUnit -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#OrganicUnit">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/org#OrganizationalUnit"/>
        <rdfs:comment xml:lang="en">Organic Unit with a hierarchical level greater than 1, which depends on a Public Law Entity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Unidad Orgánica con un nivel jerárquico mayor a 1, que depende de una Entidad de Derecho Público.</rdfs:comment>
        <rdfs:label xml:lang="en">Organic Unit</rdfs:label>
        <rdfs:label xml:lang="es">Unidad Orgánica</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#Organization">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/org#Organization"/>
        <rdfs:comment xml:lang="es">Organización de la administración pública en España</rdfs:comment>
        <rdfs:comment xml:lang="en">Organization of the public administration in Spain</rdfs:comment>
        <rdfs:label xml:lang="es">Organización</rdfs:label>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#PublicLawEntity -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/organizacion#PublicLawEntity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/org#FormalOrganization"/>
        <rdfs:comment xml:lang="es">Organismo creado para satisfacer necesidades de interés general, excluidos los de carácter mercantil o industrial; que tenga personalidad jurídica; que su actividad se financie mayoritariamente con fondos públicos o que su gestión esté sometida al control público o bien que más de la mitad de los miembros de su órgano de administración, de dirección o vigilancia, sean nombrados por el sector público.

Morales, F. J. (2007). La Contratación del Sector Público. Recuperado el 17 de febrero de 2015, de https://books.google.es/books?id=RozAMdGDMDIC&amp;pg=PA1&amp;lpg=PA1&amp;dq=la+contratación+del+sector+publico+f.+javier+escrihuela</rdfs:comment>
        <rdfs:label xml:lang="en">An organization created to meet needs of general interest, excluding those of a commercial or industrial nature; that has legal personality; whose activity is financed mainly with public funds or whose management is subject to public control or in which more than half of the members of its administrative, management or supervisory body are appointed by the public sector.</rdfs:label>
        <rdfs:label xml:lang="es">Entidad de Derecho Público</rdfs:label>
        <rdfs:label xml:lang="en">Public Law Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/GovernmentalAdministrativeRegion"/>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#"/>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Comarca -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Comarca">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/GovernmentalAdministrativeRegion"/>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#"/>
    </owl:Class>
    


