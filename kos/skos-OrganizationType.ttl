    rdfs:label "Organization type"@en ;
    rdfs:label "Tipo de organización"@es ;
    dct:title "Concept scheme grouping types of organizations in the public administration"@en ;
    dct:title "Esquema de conceptos que agrupa tipos de las organizaciones de la administración pública"@es ;
	skos:hasTopConcept edintkosorgtype:AE ;
